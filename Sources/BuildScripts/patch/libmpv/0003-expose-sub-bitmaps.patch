+/**
+ * Data for MPV_EVENT_SUB_BITMAP. (MPVKit fork extension.)
+ *
+ * Fired once per sub-rect decoded by sd_lavc for bitmap subtitle codecs
+ * (PGS / VobSub / DVB / xsub). Bitmap is BGRA, alpha-premultiplied (libavcodec
+ * convention after palette expansion).
+ *
+ * The bitmap pointer and the struct itself are owned by the event queue and
+ * freed when the event is consumed — copy out of `bgra` before processing on
+ * another thread.
+ */
+typedef struct mpv_event_sub_bitmap {
+    double pts;        // presentation time in seconds (matches video time-pos)
+    double duration;   // 0 if unknown (no end PTS in source)
+    int width;         // bitmap width in pixels
+    int height;        // bitmap height in pixels
+    int stride;        // bytes per row of `bgra`
+    int x;             // x offset on the source video frame
+    int y;             // y offset on the source video frame
+    int video_w;       // source video width (for positioning context)
+    int video_h;       // source video height
+    void *bgra;        // BGRA8 pixel buffer, premultiplied alpha
+} mpv_event_sub_bitmap;
+
